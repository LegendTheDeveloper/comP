# Exclude from VSIX package

# ===== Development Files =====

src/
daemon/src/
daemon/tests/
daemon/Cargo.toml
daemon/Cargo.lock
daemon/audit.toml
# Ship ONLY the prebuilt release binaries; exclude everything else under target/
# (the directory-slash form does not recurse in vsce's matcher, so use ** + negation).
daemon/target/**
!daemon/target/release/comp-daemon-win.exe
!daemon/target/release/comp-daemon-linux
!daemon/target/release/comp-daemon-macos

